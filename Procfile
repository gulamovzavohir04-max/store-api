web: sh -c 'python manage.py migrate && python manage.py shell -c "from django.contrib.auth import get_user_model; import os; User=get_user_model(); username=os.environ[\"DJANGO_SUPERUSER_USERNAME\"]; email=os.environ.get(\"DJANGO_SUPERUSER_EMAIL\", \"\"); password=os.environ[\"DJANGO_SUPERUSER_PASSWORD\"]; u, created = User.objects.get_or_create(username=username, defaults={\"email\": email, \"is_staff\": True, \"is_superuser\": True, \"is_active\": True}); u.email=email; u.is_staff=True; u.is_superuser=True; u.is_active=True; u.set_password(password); u.save(); print(\"superuser ready\")" && gunicorn config.wsgi:application --bind 0.0.0.0:$PORT'